# ── Server ──────────────────────────────────────────────────────────────
PORT=3000

# Secret used to sign login tokens. Generate a long random string.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Database (Railway Postgres) ─────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you attach a Postgres
# service to this project. For local dev, point it at a local Postgres.
DATABASE_URL=postgresql://user:password@localhost:5432/section8

# ── Airtable CRM mirror (optional but recommended) ──────────────────────
# Every free signup is also pushed into Joseph's Airtable so the sales team
# sees the lead. Leave AIRTABLE_TOKEN blank to disable the mirror entirely.
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=apppAaY1mCbpmXSGd
AIRTABLE_LEADS_TABLE=tblYr2IkIPKmrE013
AIRTABLE_SOURCE_LABEL=Cashflow 2.0 Academy

# ── Frontend ────────────────────────────────────────────────────────────
# Booking funnels used by the in-app "Get Help" landing page. The real links
# are baked in as defaults; set these only to override per environment.
VITE_MENTORSHIP_URL=https://go.investingsection8.com/df82de5b
VITE_DFY_URL=https://go.investingsection8.com/5249ca49

# ── Kit (ConvertKit) email list mirror (optional) ───────────────────────
# When set, every Academy signup is also subscribed to this Kit form so the
# nurture sequence can run. Leave blank to disable.
KIT_API_KEY=
KIT_FORM_ID=
KIT_TAG_ID=
